# Telegram Bot API (lead notifications)
VITE_TELEGRAM_BOT_TOKEN=your_bot_token
VITE_TELEGRAM_CHAT_ID=your_chat_id

# PocketBase instance URL (lead persistence)
VITE_POCKETBASE_URL=https://your-pocketbase-instance.com

# Base URL for canonical, OG, sitemap (no trailing slash)
VITE_SITE_URL=https://nakawke.pl

# Chat proxy (production) — if set, client uses proxy; OpenAI key not needed on client
# VITE_CHAT_PROXY_URL=https://chat-proxy.your-domain.com/api/chat

# Direct OpenAI key (required when proxy not set; use for local dev only in production)
VITE_OPENAI_API_KEY=your_openai_api_key_here

# PocketBase admin credentials for seed script (not used in client bundle)
PB_ADMIN_EMAIL=
PB_ADMIN_PASSWORD=

# --- Chat proxy (api/chat.ts or standalone) — server env only ---
# OPENAI_API_KEY=sk-...
# POCKETBASE_URL=https://pb.your-domain.com
# POCKETBASE_ADMIN_EMAIL=admin@example.com
# POCKETBASE_ADMIN_PASSWORD=your-password
# RATE_LIMIT_SALT=replace-with-random-string
# RATE_LIMIT_WINDOW_MS=600000
# RATE_LIMIT_MAX=20
# Optional for standalone proxy: ALLOWED_ORIGIN=https://nakawke.pl
