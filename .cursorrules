## рџ“¬ TELEGRAM FORM INTEGRATION вЂ” RULES

### Architecture
- Form submission logic lives in `src/services/telegram.ts`
- Never put API tokens or chat IDs in component code
- All Telegram credentials go in `.env` (never committed):

```env
VITE_TELEGRAM_BOT_TOKEN=your_bot_token
VITE_TELEGRAM_CHAT_ID=your_chat_id
```

### Service Layer (`src/services/telegram.ts`)

```ts
const TELEGRAM_API = `https://api.telegram.org/bot${import.meta.env.VITE_TELEGRAM_BOT_TOKEN}`;

export interface LeadPayload {
  name: string;
  phone: string;
  message?: string;
  packageType?: 'standard' | 'premium';
}

export async function sendLeadToTelegram(payload: LeadPayload): Promise<void> {
  const text = formatLeadMessage(payload);

  const response = await fetch(`${TELEGRAM_API}/sendMessage`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      chat_id: import.meta.env.VITE_TELEGRAM_CHAT_ID,
      text,
      parse_mode: 'HTML',
    }),
  });

  if (!response.ok) {
    const error = await response.json();
    throw new Error(`Telegram API error: ${error.description}`);
  }
}

function formatLeadMessage(payload: LeadPayload): string {
  return [
    `<b>рџ†• Nowa zgЕ‚oszenie вЂ” Na KawkД™</b>`,
    `рџ‘¤ ImiД™: ${payload.name}`,
    `рџ“ћ Telefon: ${payload.phone}`,
    payload.packageType ? `рџ“¦ Pakiet: ${payload.packageType}` : '',
    payload.message ? `рџ’¬ WiadomoЕ›Д‡: ${payload.message}` : '',
  ].filter(Boolean).join('\n');
}
```

### Form Component Rules
- Use a custom `useContactForm` hook вЂ” keep all form state and submission logic there
- Validate inputs client-side before sending (required fields, phone format, etc.)
- Show clear loading, success, and error states
- Implement rate limiting on the UI (disable submit button for 30s after success)
- Sanitize all user input before including it in the message
- Form fields must have proper `<label>` elements linked via `htmlFor` вЂ” required for SEO and a11y
- Add `autocomplete` attributes to form inputs for UX (`name`, `tel`, `email`)

### Hook Pattern (`src/hooks/useContactForm.ts`)

```ts
interface ContactFormState {
  status: 'idle' | 'loading' | 'success' | 'error';
  errorMessage: string | null;
}

export function useContactForm() {
  const [state, setState] = useState<ContactFormState>({ status: 'idle', errorMessage: null });

  const submit = async (payload: LeadPayload) => {
    setState({ status: 'loading', errorMessage: null });
    try {
      await sendLeadToTelegram(payload);
      // Also save to PocketBase вЂ” see PocketBase rules
      await saveLeadToPocketBase(payload);
      setState({ status: 'success', errorMessage: null });
    } catch (err) {
      const message = err instanceof Error ? err.message : 'Unknown error';
      console.error('[useContactForm] submission failed:', message);
      setState({ status: 'error', errorMessage: 'Something went wrong. Please try again.' });
    }
  };

  return { ...state, submit };
}
```

